# Single shared env file for all packages in local dev.
# Lives at repo root. Copy to .env.local and fill in values.
# packages/api loads this via dotenv at startup (see packages/api/src/server.ts).
# packages/web loads this via node --env-file-if-exists in the dev script.
# .env.local is gitignored and never committed.

# ----------------------------------------------------------------------------
# MongoDB Atlas
# ----------------------------------------------------------------------------
# Cluster-level connection string (no database name in the URI).
# The database name is supplied in code via the dbName option in connectDb().
#
# Local dev uses: dbName: "atlasphere-v2-dev"
# CI/CD uses:     dbName: "atlasphere-v2-test"  (via MONGODB_URI_TEST secret)
# Production uses: dbName: "atlasphere-v2"       (via MONGODB_URI in Vercel)
#
# For local dev, MONGODB_URI_TEST is also set here so you can run the test
# suite locally against the test database.
MONGODB_URI=mongodb+srv://<user>:<password>@atlasphere-cluster.9wzytf9.mongodb.net/
MONGODB_URI_TEST=mongodb+srv://<user>:<password>@atlasphere-cluster.9wzytf9.mongodb.net/
MONGODB_DB_NAME=atlasphere-v2-dev

# ----------------------------------------------------------------------------
# Auth.js (web)
# ----------------------------------------------------------------------------
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# URL of the API server (used by Next.js server components and server actions)
API_URL=http://localhost:3001

# ----------------------------------------------------------------------------
# Email (Resend)
# ----------------------------------------------------------------------------
# Leave blank to skip email sending in local dev (verification tokens are
# readable directly from MongoDB in this case).
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@atlasphere.app

# ----------------------------------------------------------------------------
# Registration gate (API)
# ----------------------------------------------------------------------------
# Comma-separated list of allowed emails, or set REGISTRATION_OPEN=true to
# allow anyone to register.
REGISTRATION_ALLOWLIST=
# REGISTRATION_OPEN=true

# ----------------------------------------------------------------------------
# Cloudflare R2
# ----------------------------------------------------------------------------
# R2_BUCKET_NAME and R2_PUBLIC_URL differ per environment:
#   Local dev:  atlasphere-v2-dev   (separate dev bucket)
#   Production: atlasphere-v2       (set in Vercel)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=atlasphere-v2-dev
R2_PUBLIC_URL=

# ----------------------------------------------------------------------------
# Map providers
# ----------------------------------------------------------------------------
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_MAPBOX_TOKEN=
# MAP_PROVIDER_OVERRIDE=mapbox
# MAPBOX_ALERT_THRESHOLD=40000

# ----------------------------------------------------------------------------
# Map viewport defaults (home page initial position)
# ----------------------------------------------------------------------------
DEFAULT_LAT=33.8337
DEFAULT_LNG=-60.8509
DEFAULT_ZOOM=2

# ----------------------------------------------------------------------------
# Default marker query (comma-separated, optional)
# If set, home page shows only markers from these users / with these tags.
# Leave empty to show all public markers.
# ----------------------------------------------------------------------------
DEFAULT_QUERY_USERIDS=
DEFAULT_QUERY_TAGS=

# ----------------------------------------------------------------------------
# V1 migration script only (scripts/migrate-v1.ts)
# Connection string for the v1 Atlas cluster (atlasphere-rob).
# Only needed when running: cd scripts && pnpm migrate-v1
# ----------------------------------------------------------------------------
MONGODB_URI_V1=mongodb+srv://<user>:<password>@atlasphere-rob.<id>.mongodb.net/
